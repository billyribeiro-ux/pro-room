PUBLIC_API_URL=http://localhost:8080

# Optional: enables the chat GIF picker. Free key from https://developers.giphy.com
PUBLIC_GIPHY_KEY=

# Optional TURN relay for the Connectivity Check probe (and future self-hosted
# LiveKit TURN). Leave blank to probe STUN only. No third-party relay is used.
PUBLIC_TURN_URL=
PUBLIC_TURN_USERNAME=
PUBLIC_TURN_CREDENTIAL=

# Brand (logo + name) shown in the room top nav — see src/lib/brand.ts.
# Leave blank to use the bundled default logo (static/brand-logo.svg) and "Trading Room".
# Replace the logo by swapping static/brand-logo.svg OR pointing this at any URL/path.
PUBLIC_BRAND_NAME=
PUBLIC_BRAND_LOGO=
