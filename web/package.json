{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:api": "cd ../server && cargo run",
		"dev:infra": "docker compose -f ../compose.yaml up -d postgres redis",
		"dev:all": "concurrently -k -n api,web -c yellow,cyan \"pnpm dev:api\" \"pnpm dev\"",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.0",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.66.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^24",
		"concurrently": "^10.0.3",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@fontsource/open-sans": "^5.2.7",
		"@fortawesome/fontawesome-free": "7.2.0",
		"dompurify": "^3.4.11",
		"livekit-client": "^2.19.2",
		"valibot": "^1.4.1"
	}
}
