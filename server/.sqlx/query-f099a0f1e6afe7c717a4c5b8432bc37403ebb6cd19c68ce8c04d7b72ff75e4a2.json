  "query": "\n        UPDATE notes\n        SET title = COALESCE($3, title),\n            body = COALESCE($4, body),\n            position = COALESCE($5, position),\n            updated_at = now()\n        WHERE room_id = $1 AND id = $2\n        RETURNING id, room_id, title, body, position, created_at, updated_at\n        ",
