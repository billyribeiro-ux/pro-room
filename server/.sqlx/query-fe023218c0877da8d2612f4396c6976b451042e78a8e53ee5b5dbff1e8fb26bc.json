{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT a.id, a.room_id, a.author_id, a.symbol, a.side, a.note, a.created_at,\n               u.display_name AS author_name\n        FROM alerts a\n        JOIN users u ON u.id = a.author_id\n        WHERE a.room_id = $1\n        ORDER BY a.created_at DESC LIMIT $2\n        ",
