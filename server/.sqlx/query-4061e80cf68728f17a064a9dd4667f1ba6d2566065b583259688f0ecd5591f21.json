  "query": "\n        SELECT m.user_id, u.email, u.display_name, m.role::text AS \"role!\", m.joined_at\n        FROM room_members m\n        JOIN users u ON u.id = m.user_id\n        WHERE m.room_id = $1\n        ORDER BY m.joined_at\n        ",
