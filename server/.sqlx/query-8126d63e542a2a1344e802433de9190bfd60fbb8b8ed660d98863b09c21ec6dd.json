{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT u.id, u.email, u.display_name,\n               u.global_role::text AS \"global_role!\",\n               u.status::text AS \"status!\"\n        FROM sessions s\n        JOIN users u ON u.id = s.user_id\n        WHERE s.token_hash = $1\n          AND s.revoked_at IS NULL\n          AND s.expires_at > now()\n        ",
