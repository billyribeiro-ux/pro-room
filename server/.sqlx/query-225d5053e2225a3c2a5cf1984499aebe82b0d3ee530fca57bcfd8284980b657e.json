{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT m.id, m.room_id, m.author_id, m.body, m.channel, m.created_at,\n               u.display_name AS author_name\n        FROM messages m\n        JOIN users u ON u.id = m.author_id\n        WHERE m.room_id = $1 AND m.channel = $2\n        ORDER BY m.created_at DESC LIMIT $3\n        ",
