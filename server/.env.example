# --- Core ---
# Address the HTTP server binds to.
APP_BIND_ADDR=0.0.0.0:8080
# Comma-separated list of allowed browser origins (the web app).
APP_CORS_ORIGINS=http://localhost:5173
# Public base URL of the web app, used to build magic-link / OAuth redirect URLs.
APP_PUBLIC_WEB_URL=http://localhost:5173
# Public base URL of this API, used as the OAuth callback host.
APP_PUBLIC_API_URL=http://localhost:8080

# --- PostgreSQL ---
DATABASE_URL=postgres://proroom:proroom@localhost:5432/proroom

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Sessions ---
# 32+ byte secret used to derive session-cookie signing/hashing keys.
SESSION_SECRET=change-me-to-a-long-random-value
SESSION_TTL_HOURS=720

# --- DEV-ONLY auth/RBAC bypass (NEVER set in production) ---
# When truthy ("1"/"true"), requests with no valid session are served as a
# synthetic super-admin so QA can exercise every endpoint without logging in.
# A real super_admin/admin user must exist in the DB for it to take effect.
# Leave UNSET (default false) everywhere except local QA. Each bypassed request
# logs a tracing::warn!("AUTH_DEV_BYPASS active").
AUTH_DEV_BYPASS=

# --- LiveKit Cloud ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- OAuth (optional; leave blank to disable a provider) ---
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# --- Email / magic links (optional; leave blank to disable) ---
SMTP_URL=
SMTP_FROM=ProTradingRoom <no-reply@example.com>
